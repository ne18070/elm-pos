{
  "name": "elm-pos",
  "version": "1.0.0",
  "description": "Multi-business Desktop POS system",
  "author": {
    "name": "Lamine MBAYE",
    "email": "whyme822@gmail.com"
  },
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "concurrently \"yarn dev:next\" \"yarn dev:electron\"",
    "dev:next": "cd renderer && next dev --port 3000",
    "dev:electron": "wait-on http://localhost:3000 && tsc -p tsconfig.main.json && cross-env ELECTRON_DEV=true electron .",
    "build": "yarn build:next && yarn build:electron",
    "build:next": "cross-env ELECTRON_BUILD=1 yarn build:next:run",
    "build:next:run": "cd renderer && next build",
    "build:electron": "tsc -p tsconfig.main.json",
    "dist": "yarn build && electron-builder",
    "dist:win": "yarn build && electron-builder --win",
    "dist:mac": "yarn build && electron-builder --mac",
    "dist:linux": "yarn build && electron-builder --linux",
    "web:dev": "cd renderer && next dev --port 3001",
    "web:build": "cd renderer && next build",
    "web:start": "cd renderer && next start --port 3001",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "postinstall": "electron-rebuild"
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.45.0",
    "@types/papaparse": "^5.5.2",
    "better-sqlite3": "^11.3.0",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "dompurify": "^3.4.0",
    "electron-store": "^10.0.0",
    "html2canvas": "^1.4.1",
    "jsbarcode": "^3.11.6",
    "jspdf": "^2.5.1",
    "lucide-react": "^0.400.0",
    "next": "^14.2.0",
    "papaparse": "^5.5.3",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "resend": "^6.10.0",
    "tailwind-merge": "^2.3.0",
    "xlsx": "^0.18.5",
    "zustand": "^4.5.0"
  },
  "optionalDependencies": {
    "escpos": "^3.0.0-alpha",
    "escpos-usb": "^3.0.0-alpha"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/dompurify": "^3.2.0",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.0",
    "cross-env": "^7.0.3",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.0",
    "electron-rebuild": "^3.2.9",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.5.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.elmpos.app",
    "productName": "ELM APP",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "renderer/out/**/*",
      "renderer/public/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "dmg": {
      "sign": false
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
