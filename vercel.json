{
  "buildCommand": "cd renderer && ../node_modules/.bin/next build",
  "outputDirectory": "renderer/.next",
  "installCommand": "yarn install --ignore-scripts",
  "devCommand": "cd renderer && ../node_modules/.bin/next dev",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/cron/workflow-processor",
      "schedule": "*/5 * * * *"
    }
  ]
}
